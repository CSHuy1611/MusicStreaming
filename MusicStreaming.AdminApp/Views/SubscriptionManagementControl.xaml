<UserControl x:Class="MusicStreaming.AdminApp.Views.SubscriptionManagementControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900" 
             Background="Transparent" Foreground="#FFFFFF">

    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#B3B3B3" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#282828" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#404040" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="5" />
            <Setter Property="CaretBrush" Value="White" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#181818" />
            <Setter Property="RowBackground" Value="#181818" />
            <Setter Property="AlternatingRowBackground" Value="#282828" />
            <Setter Property="Foreground" Value="#B3B3B3" />
            <Setter Property="BorderBrush" Value="#404040" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="None" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#282828" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="BorderBrush" Value="#404040" />
        </Style>
        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#333333" />
                    <Setter Property="Foreground" Value="#1DB954" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="DarkButtonStyle">
            <Setter Property="Background" Value="#282828"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Border Background="#121212" BorderBrush="#282828" BorderThickness="1" CornerRadius="12" Margin="10">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#181818" BorderBrush="#282828" BorderThickness="1" Padding="15" Margin="0,0,0,15" CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Tên Gói VIP:" VerticalAlignment="Center" Margin="0,5"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtName" Margin="0,5" Padding="5" ToolTip="VD: Gói Premium 1 Tháng"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Giá Gói (VNĐ):" VerticalAlignment="Center" Margin="0,5"/>
                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,5">
                        <TextBox x:Name="TxtPrice" Width="200" Padding="5" ToolTip="VD: 59000"/>
                        <TextBlock Text="VNĐ" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#1DB954" FontWeight="Bold"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Thời Hạn (Tháng):" VerticalAlignment="Center" Margin="0,5"/>
                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,5">
                        <TextBox x:Name="TxtDuration" Width="100" Padding="5" ToolTip="VD: 1, 3, 6, 12"/>
                        <TextBlock Text="Tháng" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#B3B3B3"/>
                    </StackPanel>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Trạng Thái:" VerticalAlignment="Center" Margin="0,5"/>
                    <CheckBox Grid.Row="3" Grid.Column="1" x:Name="ChkIsActive" Content="Đang kích hoạt (Cho phép user mua)" Margin="0,5" VerticalAlignment="Center" IsChecked="True"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,15">
                <Button x:Name="BtnRefresh" Content="Refresh" Width="90" Margin="5,0" Padding="5" Style="{StaticResource DarkButtonStyle}" Click="BtnRefresh_Click"/>
                <Button x:Name="BtnClear" Content="Clear" Width="90" Margin="5,0" Padding="5" Style="{StaticResource DarkButtonStyle}" Click="BtnClear_Click"/>

                <Button x:Name="BtnAdd" Content="Add" Width="90" Margin="5,0" Padding="5" Background="#1DB954" Foreground="Black" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnAdd_Click"/>
                <Button x:Name="BtnUpdate" Content="Update" Width="90" Margin="5,0" Padding="5" Background="#ffc107" Foreground="Black" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnUpdate_Click"/>
                <Button x:Name="BtnDelete" Content="Delete" Width="90" Margin="5,0" Padding="5" Background="#dc3545" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnDelete_Click"/>
            </StackPanel>

            <DataGrid Grid.Row="2" x:Name="PackagesDataGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="PackagesDataGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Tên Gói VIP" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Giá (VNĐ)" Binding="{Binding Price, StringFormat=\{0:N0\} ₫}" Width="150"/>
                    <DataGridTextColumn Header="Thời Hạn (Tháng)" Binding="{Binding DurationInMonths}" Width="150"/>
                    <DataGridCheckBoxColumn Header="Kích Hoạt" Binding="{Binding IsActive}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>

            <Border x:Name="ProgressOverlay" Grid.Row="0" Grid.RowSpan="3" Visibility="Collapsed" Background="#C0000000" CornerRadius="5" Panel.ZIndex="99">
                <Border Background="#181818" BorderBrush="#1DB954" BorderThickness="1" Width="320" Height="130" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="TxtProgressInfo" Text="Đang xử lý..." Foreground="#FFFFFF" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                        <ProgressBar x:Name="PbUpload" Height="22" Minimum="0" Maximum="100" IsIndeterminate="True" Foreground="#1DB954" Background="#282828" BorderThickness="0"/>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Border>
</UserControl>