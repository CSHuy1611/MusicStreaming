<UserControl x:Class="MusicStreaming.AdminApp.Views.LibraryManagementControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000" 
             Background="Transparent" Foreground="#FFFFFF">

    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#B3B3B3" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#282828" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#404040" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="5" />
            <Setter Property="CaretBrush" Value="White" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#282828" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="BorderBrush" Value="#404040" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#181818" />
            <Setter Property="RowBackground" Value="#181818" />
            <Setter Property="AlternatingRowBackground" Value="#282828" />
            <Setter Property="Foreground" Value="#B3B3B3" />
            <Setter Property="BorderBrush" Value="#404040" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="None" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#282828" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="BorderBrush" Value="#404040" />
        </Style>
        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#333333" />
                    <Setter Property="Foreground" Value="#1DB954" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="DarkButtonStyle">
            <Setter Property="Background" Value="#282828"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B3B3B3"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0,0,0,3"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter ContentSource="Header" Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="BorderBrush" Value="#1DB954"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="#121212" BorderBrush="#282828" BorderThickness="1" CornerRadius="12" Margin="10">
        <Grid Margin="20">
            <TabControl x:Name="LibraryTabControl">

                <TabItem Header="Thể Loại Nhạc">
                    <Grid Margin="0,20,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#181818" BorderBrush="#282828" BorderThickness="1" Padding="15" Margin="0,0,0,15" CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Tên Thể Loại:" VerticalAlignment="Center" Margin="0,5"/>
                                <TextBox Grid.Column="1" x:Name="TxtGenreName" Margin="0,5"/>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,15">
                            <Button x:Name="BtnRefreshGenre" Content="Refresh" Width="90" Margin="5,0" Padding="5" Style="{StaticResource DarkButtonStyle}" Click="BtnRefreshGenre_Click"/>
                            <Button x:Name="BtnClearGenre" Content="Clear" Width="90" Margin="5,0" Padding="5" Style="{StaticResource DarkButtonStyle}" Click="BtnClearGenre_Click"/>

                            <Button x:Name="BtnAddGenre" Content="Add" Width="90" Margin="5,0" Padding="5" Background="#1DB954" Foreground="Black" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnAddGenre_Click"/>
                            <Button x:Name="BtnUpdateGenre" Content="Update" Width="90" Margin="5,0" Padding="5" Background="#ffc107" Foreground="Black" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnUpdateGenre_Click"/>
                            <Button x:Name="BtnDeleteGenre" Content="Delete" Width="90" Margin="5,0" Padding="5" Background="#dc3545" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnDeleteGenre_Click"/>
                        </StackPanel>

                        <DataGrid Grid.Row="2" x:Name="GenresDataGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="GenresDataGrid_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                                <DataGridTextColumn Header="Tên Thể Loại" Binding="{Binding Name}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="System Playlist (Public)">
                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4*"/>
                            <ColumnDefinition Width="6*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Margin="0,0,15,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#181818" BorderBrush="#282828" BorderThickness="1" Padding="15" Margin="0,0,0,10" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="Tên Playlist:" Foreground="#1DB954" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <TextBox x:Name="TxtPlaylistName" Padding="5"/>
                                </StackPanel>
                            </Border>

                            <WrapPanel Grid.Row="1" HorizontalAlignment="Right" Margin="0,0,0,10">
                                <Button x:Name="BtnRefreshPlaylist" Content="Refresh" Width="60" Margin="2" Padding="5" Style="{StaticResource DarkButtonStyle}" Click="BtnRefreshPlaylist_Click"/>
                                <Button x:Name="BtnClearPlaylist" Content="Clear" Width="50" Margin="2" Padding="5" Style="{StaticResource DarkButtonStyle}" Click="BtnClearPlaylist_Click"/>

                                <Button x:Name="BtnAddPlaylist" Content="Add" Width="50" Margin="2" Padding="5" Background="#1DB954" Foreground="Black" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnAddPlaylist_Click"/>
                                <Button x:Name="BtnUpdatePlaylist" Content="Update" Width="60" Margin="2" Padding="5" Background="#ffc107" Foreground="Black" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnUpdatePlaylist_Click"/>
                                <Button x:Name="BtnDeletePlaylist" Content="Delete" Width="55" Margin="2" Padding="5" Background="#dc3545" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnDeletePlaylist_Click"/>
                            </WrapPanel>

                            <DataGrid Grid.Row="2" x:Name="PlaylistsDataGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="PlaylistsDataGrid_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                                    <DataGridTextColumn Header="Tên Playlist" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="Số bài" Binding="{Binding SongCount}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>

                        <Border Grid.Column="1" Background="#181818" BorderBrush="#282828" BorderThickness="1" Padding="15" CornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" x:Name="TxtSelectedPlaylistTitle" Text="Vui lòng chọn 1 Playlist bên trái để cấu hình nhạc" FontSize="15" FontWeight="Bold" Foreground="#1DB954" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                                <Border Grid.Row="1" BorderBrush="#404040" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15" Background="#282828" IsEnabled="False" x:Name="PanelAddSongToPlaylist">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Chọn nhạc:" VerticalAlignment="Center" Margin="0,0,10,10"/>
                                        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="CboAvailableSongs" HorizontalAlignment="Stretch" DisplayMemberPath="Title" SelectedValuePath="Id" Foreground="Black" Margin="0,0,0,10"/>

                                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                            <Button x:Name="BtnAddSongToPlaylist" Content="Thêm vào Playlist" Margin="0,0,10,0" Padding="15,5" Background="#1DB954" Foreground="Black" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnAddSongToPlaylist_Click"/>
                                            <Button x:Name="BtnRemoveSongFromPlaylist" Content="Xóa khỏi Playlist" Padding="15,5" Background="#dc3545" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnRemoveSongFromPlaylist_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <DataGrid Grid.Row="2" x:Name="PlaylistSongsDataGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="PlaylistSongsDataGrid_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Tên Bài Hát" Binding="{Binding Title}" Width="*"/>
                                        <DataGridTextColumn Header="Ca Sĩ" Binding="{Binding SingerName}" Width="120"/>
                                        <DataGridTextColumn Header="Thời Lượng" Binding="{Binding Duration}" Width="90"/>
                                        <DataGridTextColumn Header="Ngày Thêm" Binding="{Binding AddedDate, StringFormat=\{0:dd/MM/yyyy\}}" Width="100"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                    </Grid>
                </TabItem>

            </TabControl>
        </Grid>
    </Border>
</UserControl>