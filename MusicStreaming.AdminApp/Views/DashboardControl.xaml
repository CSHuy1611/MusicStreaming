<UserControl x:Class="MusicStreaming.AdminApp.Views.DashboardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000" 
             Background="Transparent" Foreground="#FFFFFF">

    <UserControl.Resources>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#181818" />
            <Setter Property="RowBackground" Value="#181818" />
            <Setter Property="AlternatingRowBackground" Value="#282828" />
            <Setter Property="Foreground" Value="#B3B3B3" />
            <Setter Property="BorderBrush" Value="#404040" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="None" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#282828" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="BorderBrush" Value="#404040" />
        </Style>
        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#333333" />
                    <Setter Property="Foreground" Value="#1DB954" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Background="#121212" BorderBrush="#282828" BorderThickness="1" CornerRadius="12" Margin="10">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="TỔNG QUAN HỆ THỐNG" FontSize="24" FontWeight="Bold" Foreground="#FFFFFF"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Ellipse x:Name="SignalRStatusDot" Width="12" Height="12" Fill="#6C757D" Margin="0,0,8,0"/>
                        <TextBlock x:Name="TxtSignalRStatus" Text="Đang kết nối Realtime..." FontSize="14" Foreground="#B3B3B3"/>
                    </StackPanel>
                </Grid>

                <UniformGrid Grid.Row="1" Margin="0,0,0,15" Columns="4">

                    <Border Background="#181818" BorderBrush="#282828" BorderThickness="1" CornerRadius="8" Padding="15" Margin="5">
                        <StackPanel>
                            <TextBlock Text="TỔNG NGƯỜI DÙNG" FontSize="12" FontWeight="SemiBold" Foreground="#B3B3B3"/>
                            <TextBlock x:Name="TxtTotalUsers" Text="0" FontSize="28" FontWeight="Bold" Foreground="#3B82F6" Margin="0,5,0,0"/>
                            <TextBlock x:Name="TxtVipNormalUsers" Text="0 VIP - 0 Thường" FontSize="12" Foreground="#1DB954" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#181818" BorderBrush="#282828" BorderThickness="1" CornerRadius="8" Padding="15" Margin="5">
                        <StackPanel>
                            <TextBlock Text="TỔNG BÀI HÁT" FontSize="12" FontWeight="SemiBold" Foreground="#B3B3B3"/>
                            <TextBlock x:Name="TxtTotalSongs" Text="0" FontSize="28" FontWeight="Bold" Foreground="#06B6D4" Margin="0,5,0,0"/>
                            <TextBlock x:Name="TxtActiveDisabledSongs" Text="0 Đang phát - 0 Bị ẩn" FontSize="12" Foreground="#EF4444" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#181818" BorderBrush="#282828" BorderThickness="1" CornerRadius="8" Padding="15" Margin="5">
                        <StackPanel>
                            <TextBlock Text="DOANH THU THÁNG NÀY" FontSize="12" FontWeight="SemiBold" Foreground="#B3B3B3"/>
                            <TextBlock x:Name="TxtMonthRevenue" Text="0 ₫" FontSize="28" FontWeight="Bold" Foreground="#1DB954" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#181818" BorderBrush="#282828" BorderThickness="1" CornerRadius="8" Padding="15" Margin="5">
                        <StackPanel>
                            <TextBlock Text="DOANH THU NĂM NAY" FontSize="12" FontWeight="SemiBold" Foreground="#B3B3B3"/>
                            <TextBlock x:Name="TxtYearRevenue" Text="0 ₫" FontSize="28" FontWeight="Bold" Foreground="#F59E0B" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Grid Grid.Row="3" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#181818" BorderBrush="#282828" BorderThickness="1" CornerRadius="8" Padding="15" Margin="5,0,10,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="🔥 TOP 10 NGHE NHIỀU NHẤT" FontSize="16" FontWeight="Bold" Foreground="#EF4444" Margin="0,0,0,15"/>

                            <DataGrid Grid.Row="1" x:Name="GridTopListened" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Bài Hát" Binding="{Binding Title}" Width="*"/>
                                    <DataGridTextColumn Header="Ca Sĩ" Binding="{Binding SingerName}" Width="120"/>
                                    <DataGridTextColumn Header="Lượt Nghe" Binding="{Binding Count}" Width="80">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Background="#181818" BorderBrush="#282828" BorderThickness="1" CornerRadius="8" Padding="15" Margin="10,0,5,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="❤️ TOP 10 ĐƯỢC YÊU THÍCH" FontSize="16" FontWeight="Bold" Foreground="#EC4899" Margin="0,0,0,15"/>

                            <DataGrid Grid.Row="1" x:Name="GridTopLiked" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Bài Hát" Binding="{Binding Title}" Width="*"/>
                                    <DataGridTextColumn Header="Ca Sĩ" Binding="{Binding SingerName}" Width="120"/>
                                    <DataGridTextColumn Header="Lượt Thích" Binding="{Binding Count}" Width="80">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Border>
</UserControl>