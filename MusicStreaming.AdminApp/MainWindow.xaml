<Window x:Class="MusicStreaming.AdminApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Music Streaming Admin Panel" Height="700" Width="1200" WindowStartupLocation="CenterScreen"
        Background="#121212">
    <Window.Resources>
        <Style TargetType="Button" x:Key="SpotifyMenuButtonStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B3B3B3"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center" 
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                    <Setter Property="BorderBrush" Value="#333333"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#000000">
            <StackPanel Margin="10,20,10,0">
                <TextBlock Text="ADMIN PANEL" Foreground="#1DB954" FontSize="22" FontWeight="Black" HorizontalAlignment="Left" Margin="20,0,0,30" />

                <Button x:Name="BtnDashboard" Content="Dashboard" Height="40" Margin="0,2" Style="{StaticResource SpotifyMenuButtonStyle}" Click="BtnDashboard_Click" />
                <Button x:Name="BtnManageSongs" Content="Quản lý Bài hát" Height="40" Margin="0,2" Style="{StaticResource SpotifyMenuButtonStyle}" Click="BtnManageSongs_Click" />
                <Button x:Name="BtnManageSingers" Content="Quản lý Ca sĩ" Height="40" Margin="0,2" Style="{StaticResource SpotifyMenuButtonStyle}" Click="BtnManageSingers_Click" />
                <Button x:Name="BtnManageGenres" Content="Quản lý Thư viện" Height="40" Margin="0,2" Style="{StaticResource SpotifyMenuButtonStyle}" Click="BtnManageGenres_Click" />
                <Button x:Name="BtnManageSubscriptions" Content="Quản lý Gói VIP" Height="40" Margin="0,2" Style="{StaticResource SpotifyMenuButtonStyle}" Click="BtnManageSubscriptions_Click" />
            </StackPanel>
        </Border>

        <ContentControl x:Name="MainContentControl" Grid.Column="1" Margin="20" />
    </Grid>
</Window>