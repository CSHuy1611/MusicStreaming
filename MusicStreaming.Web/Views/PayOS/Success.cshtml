@{
    ViewData["Title"] = "Thanh toán thành công";
}

<div class="container mt-5 text-center">
    <div class="card shadow p-5 mx-auto" style="background-color: #282828; color: white; border: 1px solid #1db954; border-radius: 12px; max-width: 600px;">
        <div class="mb-4" style="color: #1db954;">
            <i class="fas fa-check-circle fa-5x"></i>
        </div>
        <h2 class="fw-bold mb-3" style="color: #1db954;">Thanh toán thành công!</h2>
        <p class="text-secondary mb-4">Cảm ơn bạn đã nâng cấp gói VIP. Tài khoản của bạn đã được cập nhật quyền lợi mới.</p>
        <hr style="border-color: #444;" />
        <a href="/" class="btn fw-bold rounded-pill text-black mt-3 px-4 py-2" style="background-color: #1db954;">Quay lại Trang chủ</a>
    </div>
</div>
