@using MusicStreaming.Application.Common.Models
@using System.Text.Json
@model ArtistProfileVm

@{
    ViewData["Title"] = Model.Name;

    // TẠO CHUỖI JSON HÀNG ĐỢI CHO DANH SÁCH BÀI HÁT CỦA CA SĨ
    var artistQueueJson = "";
    if (Model.Songs != null && Model.Songs.Any())
    {
        artistQueueJson = JsonSerializer.Serialize(Model.Songs.Select(s => new
        {
            id = s.Id,
            audioUrl = s.AudioUrl,
            title = s.Title,
            artistName = s.ArtistName,
            imageUrl = s.ImageUrl,
            isVip = s.IsVip
        }));
    }
}

<div class="playlist-header d-flex align-items-end p-4 text-white"
     style="background: linear-gradient(to bottom, #4a4a4a, #121212); height: 350px;">

    <img src="@Model.AvatarUrl" class="shadow-lg rounded-circle"
         style="width: 250px; height: 250px; object-fit: cover; box-shadow: 0 4px 60px rgba(0,0,0,0.5); border: 4px solid #282828;">

    <div class="ms-5">
        <span class="text-uppercase fw-bold small">Nghệ sĩ xác thực <i class="fa-solid fa-circle-check text-primary ms-1"></i></span>
        <h1 class="display-2 fw-bold mb-3" style="font-weight: 900;">@Model.Name</h1>

        <p class="text-white-50" style="max-width: 600px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
            @(string.IsNullOrEmpty(Model.Bio) ? "Nghệ sĩ này chưa cập nhật tiểu sử." : Model.Bio)
        </p>

        <div class="d-flex align-items-center mt-4">
            <button class="btn btn-success rounded-circle d-flex align-items-center justify-content-center shadow-lg hover-scale"
                    style="width: 64px; height: 64px;"
                    onclick="playQueue('artistQueueData', 0)">
                <i class="fa-solid fa-play text-black fs-3 ms-1"></i>
            </button>
            <button class="btn btn-outline-light rounded-pill ms-4 fw-bold px-4 py-2 hover-scale">Theo dõi</button>
            <i class="fa-solid fa-ellipsis fs-3 ms-4 text-secondary hover-white" style="cursor: pointer;"></i>
        </div>
    </div>
</div>

<div class="container-fluid p-4" style="background: linear-gradient(to bottom, #121212, #000); min-height: 50vh;">

    <input type="hidden" id="artistQueueData" value="@artistQueueJson" />

    <h4 class="fw-bold text-white mb-4">Bài hát phổ biến</h4>

    @if (Model.Songs != null && Model.Songs.Any())
    {
        int index = 1;
        int jsIndex = 0; // Biến đếm Index cho Javascript (bắt đầu từ 0)

        foreach (var song in Model.Songs)
        {
            <div class="row align-items-center px-3 py-2 rounded hover-bg-light group-play-btn" style="cursor: pointer;">

                <div class="col-1 text-secondary position-relative">
                    <span class="song-index">@index</span>
                    <i class="fa-solid fa-play text-white position-absolute top-50 start-0 translate-middle-y ms-3 song-play-icon"
                       style="display: none; font-size: 12px;"
                       onclick="playQueue('artistQueueData', @jsIndex)">
                    </i>
                </div>

                <div class="col-6 d-flex align-items-center">
                    <img src="@song.ImageUrl" class="rounded me-3" width="40" height="40">
                    <div>
                        <div class="text-white fw-bold mb-0 text-truncate">
                            @song.Title
                            @if (song.IsVip)
                            {
                                <span class="badge bg-warning text-dark ms-2" style="font-size: 8px;">VIP</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="col-4 text-secondary small hover-white">
                    @song.ArtistName
                </div>

                <div class="col-1 text-end text-secondary small">
                    @song.DurationFormatted
                </div>
            </div>
            index++;
            jsIndex++;
        }
    }
    else
    {
        <div class="text-center text-secondary py-5">
            Nghệ sĩ này chưa có bài hát nào trên hệ thống.
        </div>
    }
</div>

<style>
    .hover-bg-light:hover {
        background-color: rgba(255, 255, 255, 0.1);
    }

        .hover-bg-light:hover .song-index {
            display: none;
        }

        .hover-bg-light:hover .song-play-icon {
            display: block !important;
        }

    .hover-white:hover {
        color: white !important;
    }

    .hover-scale:hover {
        transform: scale(1.05);
        transition: 0.2s;
    }
</style>